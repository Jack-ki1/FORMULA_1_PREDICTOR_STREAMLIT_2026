# F1 Prediction System — Environment Variables
# Copy to .env and fill in values

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Optional: Ergast F1 API (for live data fetching)
ERGAST_API_BASE=http://ergast.com/api/f1

# Optional: OpenWeatherMap (for pre-race weather forecast)
OPENWEATHER_API_KEY=1ab93c353fb9d3f118911534cbf499ac
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Prediction model settings
MODEL_RECENCY_WINDOW=8        # number of recent races to weight heavily
MODEL_ELO_K_FACTOR=32
MODEL_DNF_SMOOTHING=0.1       # Laplace smoothing for rare events

# Report output
REPORT_OUTPUT_DIR=./output
